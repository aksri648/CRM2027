# Channel Service API Key (must match backend's CHANNEL_SERVICE_API_KEY)
CHANNEL_SERVICE_API_KEY="channel-service-api-key"

# Port
PORT=8001

# CRM Backend URL (for callbacks)
# Set to your backend's public URL on Render
CRM_CALLBACK_URL="https://your-backend.onrender.com/api/v1/callbacks"

# ============================================
# OpenTelemetry Configuration
# ============================================
# Service identification
OTEL_SERVICE_NAME="channelization-microservice"
OTEL_SERVICE_VERSION="1.0.0"
DEPLOYMENT_ENVIRONMENT="development"

# OTEL Collector endpoint (telemetry-dashboard FastAPI receiver)
# Local development: http://localhost:8002
# Render (production): https://xeno-crm-2027-telemetry.onrender.com
# Code appends /v1/traces, /v1/metrics, /v1/logs to this base URL.
OTEL_EXPORTER_OTLP_ENDPOINT="https://xeno-crm-2027-telemetry.onrender.com"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_TIMEOUT="10"

# Tracing configuration
# Sampling rate: 0.1 = 10% of traces are captured
OTEL_TRACE_SAMPLING_RATE="0.1"
OTEL_TRACE_EXPORT_INTERVAL="5000"

# Metrics configuration
# Export interval in milliseconds
OTEL_METRICS_EXPORT_INTERVAL="30000"

# Logging
OTEL_LOG_LEVEL="INFO"