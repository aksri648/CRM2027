# Application
APP_NAME="Xeno Mini CRM"
DEBUG=false
API_V1_PREFIX="/api/v1"

# Database
DATABASE_URL="sqlite:///./xeno_crm.db"

# JWT
SECRET_KEY="your-secret-key-here"

# Clerk Authentication
CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"
CLERK_JWKS_URL="https://api.clerk.dev/v1/jwks"
CLERK_ISSUER="https://clerk.example.com"
CLERK_AUDIENCE=""

# Channel Service
# Set to your channel service's public URL on Render (e.g., https://channel-service.onrender.com)
CHANNEL_SERVICE_URL="https://channel-service.onrender.com"
CHANNEL_SERVICE_API_KEY="channel-service-api-key"

# AI (kimchi.dev)
KIMCHI_BASE_URL="https://api.kimchi.dev/v1"
KIMCHI_API_KEY="your-kimchi-api-key"
AI_MODEL="gpt-4o-mini"

# CRM Callback URL (for channel service to call back)
# Set to this backend's public URL on Render (e.g., https://your-backend.onrender.com/api/v1/callbacks)
CRM_CALLBACK_URL="https://your-backend.onrender.com/api/v1/callbacks"

# CORS - Allowed origins (comma-separated)
# Add your frontend's public URL from Render
ALLOWED_ORIGINS="https://your-frontend.onrender.com"