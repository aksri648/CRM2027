# Telemetry Dashboard Configuration

# Service URLs - Set to your services' public URLs on Render
APP_SERVICE_URL="https://your-backend.onrender.com"
CHANNEL_SERVICE_URL="https://your-channel-service.onrender.com"

# Service Info
SERVICE_NAME="telemetry-dashboard"
SERVICE_VERSION="1.0.0"
DEPLOYMENT_ENVIRONMENT="production"

# Collection Settings
METRICS_COLLECTION_INTERVAL_MS=30000
LOG_STORAGE_MAX_SIZE=1000

# OpenTelemetry (for exporting traces/metrics to external collectors)
# OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-collector:4317"
# OTEL_SERVICE_NAME="telemetry-dashboard"

# Logging
LOG_LEVEL="INFO"